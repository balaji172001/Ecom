{
  "name": "sivakasi-crackers",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspace=frontend && npm install --workspace=backend",
    "start:frontend": "npm --workspace=frontend start",
    "start:backend": "npm --workspace=backend start",
    "start": "npm run start:backend & npm run start:frontend",
    "build:all": "node deploy.js",
    "deploy": "node deploy.js"
  }
}